<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Name</label>
    <input type="text" id="name" class="form-control" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Surname</label>
    <input type="text" id="surname" class="form-control" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Date of birth</label>
    <input type="text" id="dob" class="form-control" placeholder="1991-10-30">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Email Address</label>
    <input type="email" id="email" class="form-control" placeholder="test@gmail.com">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">User Name</label>
    <input type="text" id="username" class="form-control" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Identifier</label>
    <input type="text" id="identifier" class="form-control" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Cell Number</label>
    <input type="text" id="cellnumber" class="form-control" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Password</label>
    <input type="password" class="form-control" id="password" placeholder="">
</div>

<div class="mb-3">
    <label for="exampleFormControlInput1" class="form-label">Confirm Password</label>
    <input type="password" class="form-control" id="passwordconfirm" placeholder="">
</div>

<div class="mb-3">
    <button type="button" id="create" class="btn btn-warning">Create</button>
    <button type="button" id="back" class="btn btn-secondary">Go Back</button>
</div>

<div class="mb-3">
    <br />
    <br />
</div>

<script>

       document.getElementById("back").onclick = function () {
           location.href = "/Account/Login";
       };

       document.getElementById("create").onclick = function () {
           var name = document.getElementById("name").value;
           var surname = document.getElementById("surname").value;
           var dob = document.getElementById("dob").value;
           var email = document.getElementById("email").value;
           var identifier = document.getElementById("identifier").value;
           var username = document.getElementById("username").value;
           var cellnumber = document.getElementById("cellnumber").value;
           var password = document.getElementById("password").value;
           var passwordconfirm = document.getElementById("passwordconfirm").value;

            if (isDateValid(dob) == false) {
                alert("Please enter a valid date of birth.");
                return;
            }

           if (name === "" || surname === ""
           || dob === "" || email === ""
           || identifier === ""
           || username === ""
           || cellnumber === ""
           || password === "" || passwordconfirm === "") {
               alert("Please fill in all fields.");
               return;
           }

           if (password !== passwordconfirm) {
               alert("Passwords do not match.");
               return;
           }

           /* var emailPattern = ;

           // if (!emailPattern.test(email)) {
           //     alert("Please enter a valid email address.");
           //     return;
           // }
           */

           var dobPattern = /^\d{4}-\d{2}-\d{2}$/;

           if (!dobPattern.test(dob)) {
               alert("Please enter the date of birth in the format YYYY-MM-DD.");
               return;
           }

           fetch('/Account/Create', {
               method: 'POST',
               headers: {
                   'Content-Type': 'application/json'
               },
               body: JSON.stringify({
                   Name: name,
                   Surname: surname,
                   DateOfBirth: dob,
                   Email: email,
                   cellnumber: cellnumber,
                   Identifier: identifier,
                   Username: username,
                   Password: password
               })
           })
               .then(response => {
                   if (response.ok) {
                       //alert(response);
                       return response.json();
                   } else {
                       response.text().then(text => alert("Error: " + text));
                   }
                 }) .then(data => {
                   console.log('Parsed JSON:', data.success); // This contains the actual data

                   if (data.success) {
                       alert("Account created successfully!");
                       location.href = "/Account/Login";
                   } else {
                       alert("Error: " + (data.errors.length > 0 ? data.errors.join(", ") : "Unknown error"));
                   }

               })
               .catch(error => {
                   console.error('Error:', error);
                   alert("An error occurred while creating the account.");
               });

       };

    function isDateValid(dateStr) {
         return !isNaN(new Date(dateStr));
    }

</script>