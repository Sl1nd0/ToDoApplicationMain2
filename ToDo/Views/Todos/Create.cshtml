@{
}

@model ToDo.Models.ListToDosResult;

<body onload="setUserName('@Model.GetUserRequest.Email')">

    <p class="card-text" style="color:red" id="error"></p>

    <!--Create a task-->
    <div class="card pb-4">
        <div class="card-header">
            <center>Create Tasks</center>
        </div>
        <div class="row pt-4">
            <div class="col-md-12">
                <center>
                    <p class="card-text">Please create a new task:</p>
                    <label for="title">Title:</label><br>
                    <input type="text" id="todoTitle" name="todoTitle"><br>
                    <label for="title">Task:</label><br>
                    <div class="container"><textarea id="task" cols="120" rows="5" style="max-width:100%;"></textarea></div>
                    <div class="row pt-4">
                        <div class="col-md-4 pb-4 pl-3 pr-3"></div>
                        <div class="col-md-4 pb-4 pl-3 pr-3">
                            <a onclick="createATask('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password', '@Model.GetUserRequest.UserID')" class="btn btn-primary">Create</a>
                            <a onclick="goBackToMain('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password', '@Model.GetUserRequest.UserID')" class="btn btn-secondary">Go Back</a>
                        </div>
                        <div class="col-md-4 pb-4 pl-3 pr-3"></div>
                    </div>
                </center>
            </div>
        </div>
    </div>
    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
    <!--Create a task-->

</body>

<script src="./js/index.js"></script>