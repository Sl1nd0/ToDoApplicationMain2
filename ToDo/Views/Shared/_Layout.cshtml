 *@

<!DOCTYPE html>
<html lang="en">

<!--Another head-->

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ToDo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ToDo.styles.css" asp-append-version="true" />

    <meta charset="utf-8">
    <title>ToDo</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Roboto:wght@700;800&display=swap"
          rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.4/font/bootstrap-icons.css">

    <!-- Libraries Stylesheet -->
    <link href="lib/animate/animate.min.css" rel="stylesheet">
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="css/style.css" rel="stylesheet">
</head>


<!--End-->
<body onload="">
    <header>
        <!--
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">ToDo</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
        -->
        <!-- Navbar Start -->
        <div class="container-fluid bg-white sticky-top wow fadeIn" data-wow-delay="0.1s">
            <div class="container">
                <nav class="navbar navbar-expand-lg bg-white navbar-light p-lg-0">
                    <a href="index.html" class="navbar-brand d-lg-none">
                        <h1 class="fw-bold m-0">ToDo</h1>
                    </a>
                    <button type="button" class="navbar-toggler me-0" data-bs-toggle="collapse"
                            data-bs-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarCollapse">
                        <div class="navbar-nav">
                            <a href="/" class="nav-item nav-link active">Home</a>

                            <!-- <a href="about.html" class="nav-item nav-link">About</a> -->
                            <!-- <a href="service.html" class="nav-item nav-link">Services</a> -->
                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">ToDo</a>
                                <div class="dropdown-menu bg-light rounded-0 rounded-bottom m-0">
                                    <!--  <a href="feature.html" class="dropdown-item">Create a task for the day</a>
                                        <a href="team.html" class="dropdown-item">Users</a> -->
                                </div>
                            </div>
                            <!-- <a href="contact.html" class="nav-item nav-link">Contact</a> -->
                        </div>


                        @if (Model != null)
                        {
                            if (@Model.GetUserRequest.Email != null)
                            {
                                <div>
                                    <a href="#" id="user" onclick="editProfileDetails('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="nav-item nav-link active">@Model.GetUserRequest.Email</a>
                                </div>
                            }
                            else
                            {
                                <div>
                                    <a href="#" id="user" class="nav-item nav-link active">User</a>
                                </div>
                            }
                        }


                        @if (Model != null)
                        {
                            <div>
                                <a href="#" id="connect" onclick="connect('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="nav-item nav-link active">Connect</a>
                            </div>

                            <div>
                                <a href="#" id="connect" onclick="viewConnections('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="nav-item nav-link active">View Connections</a>
                            </div>
                        }
                        else
                        {

                            <div>
                                <a href="#" id="connect" onclick="connect('', '')" class="nav-item nav-link active">Connect</a>
                            </div>

                            <div>
                                <a href="#" id="connect" onclick="viewConnections('', '')" class="nav-item nav-link active">View Connections</a>
                            </div>
                        }

                        <div class="ms-auto">
                            <a id="createaccount" onclick="createAccount('Account/Create')" class="btn btn-primary py-2 px-1">Create</a>
                            <a id="loginaccount" onclick="loginAccount('Account/Login')" class="btn btn-primary py-2 px-1">Login</a>
                            <a href="#" onclick="logout()" id="logoutaccount" class="btn btn-primary py-2 px-1">Logout</a>
                        </div>

                    </div>
                </nav>
            </div>
        </div>
        <!-- Navbar End -->

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted pt-4">
        <div class="container">
            &copy; 2025 - ToDo - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

<script src="./Account/js/layout.js"></script>
<script src="./js/index.js"></script>

</html>

