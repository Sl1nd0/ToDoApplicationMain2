<body onload="setUser('@Model.GetUserRequest.Email')">


    <input type="hidden" id="myuser" value="" />

    <div class="row">
        <div class="col-md-4 pb-4"></div>
        <div class="col-md-4 pb-4">
            <div class="card">
                <div class="card-body">
                    <center>
                        <p class="card-text">Click here to go back</p>
                        <a onclick="goBackToMain('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password', @Model.GetUserRequest.UserID)" class="btn btn-secondary">Go Back</a>
                    </center>
                </div>
            </div>
        </div>
        <div class="col-md-4 pb-4"></div>
    </div>

    <div class="card pb-4">
        <div class="card-header">
            <center>Connections</center>
        </div>
        <div class="row pt-4">

            @foreach (var task in Model.ListConnectionsByUserIdResult)
            {
                <div class="col-md-4 pb-4 pl-3">
                    <div class="card">
                        <div class="card-body">
                            <center>
                                <h5 class="card-title">@task.Name @task.Surname</h5>
                                <p class="card-text">@task.Email</p>

                                <a href="#" id="downloadtaskreport" onclick="downloadCSV('@task.Email')"><u>Download task report</u></a>&nbsp;
                                <a href="#" id="edittask" onclick="viewTasks( '@Model.GetUserRequest.Email',  '@Model.GetUserRequest.Password', @task.ConnectionID, @Model.GetUserRequest.UserID, '@task.Email')"><u>View tasks</u></a>&nbsp;
                                <a href="#" id="deletetask" onclick="deleteConnection(@task.Id, '@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password',  @Model.GetUserRequest.UserID)"><u>Delete</u></a>

                            </center>
                        </div>
                    </div>
                </div>
                @* 
                    <div class="col-md-4 pb-4">
                        <div class="card">
                            <div class="card-body">
                                <center>
                                    <h5 class="card-title">Card title</h5>
                                    <p class="card-text">@task._ToDo</p>
                                    <a id="edittask" onclick="editTask('@Model.GetUserRequest.Email')" class="btn btn-primary">Edit</a>
                                    <a id="commenttask" onclick="commentTask('@Model.GetUserRequest.Email')" class="btn btn-primary">Comment</a>
                                    <a id="deletetask" onclick="deleteTask('@Model.GetUserRequest.Email')" class="btn btn-danger">Delete</a>
                                </center>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 pb-4 pr-3">
                        <div class="card">
                            <div class="card-body">
                                <center>
                                    <h5 class="card-title">Card title</h5>
                                    <p class="card-text">@task._ToDo</p>

                                    <a id="edittask" onclick="editTask('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="btn btn-primary">Edit</a>
                                    <a id="commenttask" onclick="commentTask('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="btn btn-primary">Comment</a>
                                    <a id="deletetask" onclick="deleteTask('@Model.GetUserRequest.Email', '@Model.GetUserRequest.Password')" class="btn btn-danger">Delete</a>
                                </center>
                            </div>
                        </div>
                    </div> *@               
                }
        </div>
    </div>

    <div class="mb-3">
        <br />
        <br />
    </div>

