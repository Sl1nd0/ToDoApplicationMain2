@{
    var newuser = @Model.GetUserRequest.Email;
}

@model ToDo.Models.ListToDosResult;

@* Indexed

@Model.UserName
 *@

<head>
    <meta charset="utf-8">
    <title>ToDo</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Roboto:wght@700;800&display=swap"
          rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.4/font/bootstrap-icons.css">

    <!-- Libraries Stylesheet -->
    <link href="lib/animate/animate.min.css" rel="stylesheet">
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="css/style.css" rel="stylesheet">
</head>



<body onload="setUser('@Model.GetUserRequest.Email')">


    <input type="hidden" id="myuser" value="" />

    <div class="row">

        <div class="col-md-4 pb-4"></div>

        <div class="col-md-4 pb-4">
            <div class="card">
                <div class="card-body">
                    <center>
                        <p class="card-text">Please click here to create a task</p>
                        <a onclick="createATask('@Model.GetUserRequest.Email','@Model.GetUserRequest.Password', '@Model.GetUserRequest.UserID')" class="btn btn-success">Create task</a>
                    </center>
                </div>
            </div>
        </div>

        <div class="col-md-4 pb-4"></div>
    </div>

    <div class="card pb-4">
        <div class="card-header">
            <center>Account</center>
        </div>
        <div class="row pt-4">

            <div class="col-md-4 pb-4 pl-3">


                <div class="card">
                    <div class="card-body">


                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Name</label>
                            <input type="text" id="name" class="form-control" placeholder="">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Surname</label>
                            <input type="text" id="surname" class="form-control" placeholder="">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Date of birth</label>
                            <input type="text" id="dob" class="form-control" placeholder="1991-10-30">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Email Address</label>
                            <input type="email" id="email" class="form-control" placeholder="test@gmail.com">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">User Name</label>
                            <input type="text" id="username" class="form-control" placeholder="">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Identifier</label>
                            <input type="text" id="identifier" class="form-control" placeholder="">
                        </div>

                        <div class="mb-3">
                            <label for="exampleFormControlInput1" class="form-label">Cell Number</label>
                            <input type="text" id="cellnumber" class="form-control" placeholder="">
                        </div>

                    </div>
                </div>


            </div>

        </div>
    </div>

    <div class="mb-3">
        <br />
        <br />
    </div>

    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
</body>

<script src="./js/index.js"></script>